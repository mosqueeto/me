--
-- Table structure for table `registrar_reports`
--

DROP TABLE IF EXISTS `registrar_reports`;
CREATE TABLE `registrar_reports` (
  `id` int(11) NOT NULL auto_increment,
  `registry_id` int(11) NOT NULL default '0',
  `registrar_name` varchar(255) NOT NULL default '',
  `iana_id` int(11) NOT NULL default '0',
  `adds_1yr` int(11) default '0',
  `adds_2yr` int(11) default '0',
  `adds_3yr` int(11) default '0',
  `adds_4yr` int(11) default '0',
  `adds_5yr` int(11) default '0',
  `adds_6yr` int(11) default '0',
  `adds_7yr` int(11) default '0',
  `adds_8yr` int(11) default '0',
  `adds_9yr` int(11) default '0',
  `adds_10yr` int(11) default '0',
  `transfers` int(11) default '0',
  `renews_1yr` int(11) default '0',
  `renews_2yr` int(11) default '0',
  `renews_3yr` int(11) default '0',
  `renews_4yr` int(11) default '0',
  `renews_5yr` int(11) default '0',
  `renews_6yr` int(11) default '0',
  `renews_7yr` int(11) default '0',
  `renews_8yr` int(11) default '0',
  `renews_9yr` int(11) default '0',
  `renews_10yr` int(11) default '0',
  `year` int(11) default NULL,
  `quarter` int(11) default NULL,
  `cost_this_term` float default NULL,
  `defer` int(11) default NULL,
  PRIMARY KEY  (`id`)
) ENGINE=MyISAM DEFAULT CHARSET=latin1;

--
-- Dumping data for table `registrar_reports`
--


/*!40000 ALTER TABLE `registrar_reports` DISABLE KEYS */;
LOCK TABLES `registrar_reports` WRITE;
UNLOCK TABLES;
/*!40000 ALTER TABLE `registrar_reports` ENABLE KEYS */;

--
-- Table structure for table `registrars`
--

DROP TABLE IF EXISTS `registrars`;
CREATE TABLE `registrars` (
  `id` int(11) NOT NULL auto_increment,
  `registrar` varchar(255) NOT NULL default '',
  `iana_id` int(11) NOT NULL default '0',
  `defer` int(11) NOT NULL default '0',
  `notes` text,
  `fundware_id` int(11) default NULL,
  PRIMARY KEY  (`id`)
) ENGINE=MyISAM DEFAULT CHARSET=latin1;

--
-- Dumping data for table `registrars`
